---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/paths';
import { INCIDENT_DB_URL, FORMSPREE_ENDPOINT } from '../lib/site';

// The contact banner — a calm, on-palette watercolour wash in the coalition's
// greens, teals, and warm sand. Routed through Astro's image pipeline so the
// build emits optimized responsive variants instead of the raw ~1.9 MB PNG.
import contactBanner from '../assets/contact-wash.png';

// The Hugo contact page used a Formspree-backed form with the intro copy below.
// That form is reinstated here against the owner's existing Formspree form
// (FORMSPREE_ENDPOINT in src/lib/site.ts). Formspree handles the POST off-site,
// so the static GitHub Pages host does not need to process submissions itself.
// The form submits via AJAX for an inline success/error state, and degrades to
// a plain form POST (action/method on the <form>) when JavaScript is disabled.
---
<BaseLayout
  title="Contact"
  description="Join our growing movement to bring the principles of the Common Humanity Coalition to life in your community."
>
  <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6 sm:py-14">
    <header>
      <h1 class="font-display text-3xl font-semibold text-ink sm:text-4xl">Contact</h1>
      <p class="mt-5 text-lg leading-relaxed text-ink-soft">
        Join our growing movement to bring the principles of the Common Humanity Coalition to
        life in your community. Whether you have a question, want to get involved, or simply
        wish to stay informed, we welcome you to reach out. Together, we can foster greater
        understanding, celebrate our unique individuality, and unite people across all
        backgrounds in our shared human journey. Your voice and participation are invaluable
        as we work to create a more compassionate, connected world. Reach out to us today and
        be part of the change.
      </p>
    </header>

    <figure class="mt-10 overflow-hidden rounded-2xl border border-line">
      <Image
        src={contactBanner}
        alt="A soft watercolour wash in calm greens, teal, and warm sand on textured paper — overlapping horizontal washes suggesting a quiet, open landscape."
        widths={[640, 768, 1024]}
        sizes="(min-width: 768px) 768px, 92vw"
        loading="lazy"
        format="webp"
        quality={72}
        class="w-full"
      />
    </figure>

    <section aria-labelledby="form-h" class="mt-12">
      <h2 id="form-h" class="font-display text-2xl font-semibold text-ink">Send us a message</h2>
      <div class="mt-6 rounded-2xl border border-line bg-surface p-6 sm:p-8">
        <form
          id="contact-form"
          action={FORMSPREE_ENDPOINT}
          method="POST"
          class="grid gap-5"
        >
          <div class="grid gap-1.5">
            <label for="cf-name" class="text-sm font-semibold text-ink">Name</label>
            <input
              type="text"
              id="cf-name"
              name="name"
              required
              autocomplete="name"
              class="rounded-md border border-line bg-paper px-3.5 py-2.5 text-sm text-ink placeholder:text-ink-faint transition-colors hover:border-accent-ring focus:border-accent-ring"
            />
          </div>

          <div class="grid gap-1.5">
            <label for="cf-email" class="text-sm font-semibold text-ink">Email</label>
            <input
              type="email"
              id="cf-email"
              name="email"
              required
              autocomplete="email"
              class="rounded-md border border-line bg-paper px-3.5 py-2.5 text-sm text-ink placeholder:text-ink-faint transition-colors hover:border-accent-ring focus:border-accent-ring"
            />
          </div>

          <div class="grid gap-1.5">
            <label for="cf-message" class="text-sm font-semibold text-ink">Message</label>
            <textarea
              id="cf-message"
              name="message"
              required
              rows="5"
              autocomplete="off"
              class="resize-y rounded-md border border-line bg-paper px-3.5 py-2.5 text-sm text-ink placeholder:text-ink-faint transition-colors hover:border-accent-ring focus:border-accent-ring"
            ></textarea>
          </div>

          {/* Honeypot — hidden from users; Formspree drops submissions that fill it. */}
          <div aria-hidden="true" class="absolute -left-[9999px] h-0 w-0 overflow-hidden">
            <label for="cf-gotcha">Leave this field empty</label>
            <input
              type="text"
              id="cf-gotcha"
              name="_gotcha"
              tabindex="-1"
              autocomplete="off"
            />
          </div>

          <div>
            <button
              type="submit"
              class="rounded-md bg-accent px-5 py-2.5 text-sm font-semibold text-white no-underline shadow-sm transition-colors hover:bg-accent-hover"
            >
              Send message
            </button>
          </div>
        </form>

        {/* Inline status panels, toggled by the AJAX handler below. */}
        <p
          id="contact-success"
          role="status"
          hidden
          class="text-sm leading-relaxed text-accent"
        >
          Thank you — we&rsquo;ve received your message.
        </p>
        <p
          id="contact-error"
          role="alert"
          hidden
          class="text-sm leading-relaxed text-ink-soft"
        >
          Something went wrong — please try again.
        </p>
      </div>
    </section>

    <section aria-labelledby="ways-h" class="mt-12">
      <h2 id="ways-h" class="font-display text-2xl font-semibold text-ink">Ways to get involved</h2>
      <div class="mt-6 grid gap-5 sm:grid-cols-2">
        <div class="rounded-xl border border-line bg-surface p-6">
          <h3 class="font-display text-lg font-semibold text-accent">Join the movement</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-soft">
            Connect with your nearest chapter, attend a community forum, or support our
            initiatives. Read more about who we are and how we organize.
          </p>
          <a
            href={withBase('/about')}
            class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-accent no-underline hover:text-accent-hover"
          >
            About the Coalition
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
        <div class="rounded-xl border border-line bg-surface p-6">
          <h3 class="font-display text-lg font-semibold text-accent">Explore the record</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-soft">
            Our public Incident Database documents moments across Canada where institutions
            fell short of our shared principles—so that what is recorded can be understood,
            and what is understood can be changed.
          </p>
          <a
            href={INCIDENT_DB_URL}
            target="_blank"
            rel="noopener"
            class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-accent no-underline hover:text-accent-hover"
          >
            Explore the Incident Database
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </section>
  </div>

  <script>
    // Progressive enhancement: submit the contact form via fetch so we can show
    // an inline success/error state without a full page navigation. With JS
    // disabled the form still POSTs to Formspree natively (action/method set on
    // the <form> element), so this only enriches the baseline behaviour.
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const success = document.getElementById('contact-success');
    const error = document.getElementById('contact-error');

    if (form && success && error) {
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        error.hidden = true;
        if (submitBtn) submitBtn.disabled = true;

        try {
          const response = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { Accept: 'application/json' },
          });

          if (response.ok) {
            // Replace the form with the success message.
            form.hidden = true;
            success.hidden = false;
            success.focus?.();
          } else {
            if (submitBtn) submitBtn.disabled = false;
            error.hidden = false;
          }
        } catch {
          if (submitBtn) submitBtn.disabled = false;
          error.hidden = false;
        }
      });
    }
  </script>
</BaseLayout>
