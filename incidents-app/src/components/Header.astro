---
import { withBase } from '../lib/paths';

// Links are authored as root-relative paths and run through withBase() so they
// resolve under any mount point. isActive() compares against the *based*
// versions because Astro.url.pathname already carries the base prefix.
const links = [
  { href: '/', label: 'Overview' },
  { href: '/incidents', label: 'Browse' },
  { href: '/statistics', label: 'Statistics' },
  { href: '/about', label: 'About' },
];
// Normalise current path (strip trailing slash). Compare against based hrefs
// (also trailing-slash-stripped) so /incidents/* still highlights "Browse".
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
function isActive(href: string): boolean {
  const based = withBase(href).replace(/\/+$/, '') || '/';
  if (href === '/') return path === based;
  return path === based || path.startsWith(based + '/');
}
---
<header class="border-b border-line bg-surface/90 backdrop-blur supports-[backdrop-filter]:bg-surface/75 sticky top-0 z-40">
  <div class="mx-auto flex max-w-6xl flex-wrap items-center gap-x-6 gap-y-2 px-4 py-3 sm:px-6">
    <a href={withBase('/')} class="group flex items-baseline gap-2 no-underline">
      <span class="font-display text-lg font-semibold text-ink">Incident Database</span>
      <span class="hidden text-sm text-ink-faint sm:inline">Common Humanity Coalition</span>
    </a>

    <nav aria-label="Primary" class="order-3 -mx-1 w-full overflow-x-auto sm:order-2 sm:ml-auto sm:w-auto">
      <ul class="flex items-center gap-1 text-sm">
        {links.map((l) => (
          <li>
            <a
              href={withBase(l.href)}
              aria-current={isActive(l.href) ? 'page' : undefined}
              class:list={[
                'rounded-md px-3 py-1.5 font-medium no-underline transition-colors',
                isActive(l.href)
                  ? 'bg-accent-soft text-accent'
                  : 'text-ink-soft hover:bg-sand-50 hover:text-ink',
              ]}
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a
      href="https://commonhumanity.us"
      class="order-2 ml-auto rounded-md border border-line px-3 py-1.5 text-sm font-medium text-ink-soft no-underline transition-colors hover:border-accent-ring hover:text-accent sm:order-3 sm:ml-0"
      rel="noopener"
    >
      commonhumanity.us<span aria-hidden="true" class="ml-1">&rarr;</span>
    </a>
  </div>
</header>
